# Next.js frontend configuration.
# Copy to .env.local and adjust per environment.

# Server-side only: backend URL that next.config.ts rewrites "/api/*" to.
# Not exposed to the browser. Defaults to http://localhost:8000 when unset.
BACKEND_API_URL=http://localhost:8000

# Optional: call the backend directly instead of via the "/api" rewrite proxy
# (requires CORS_ORIGINS on the backend to include this frontend's origin).
# Leave unset to use the same-origin "/api" proxy (recommended for browsers).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: sent as X-API-Key when calling the backend directly.
# NEXT_PUBLIC_API_KEY=
