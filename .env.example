# FastAPI backend configuration.
# Copy to .env (or export in your shell) and adjust per environment.

# Comma-separated list of origins allowed to call the API via CORS.
# Defaults to http://localhost:3000 (Next.js dev server) when unset.
CORS_ORIGINS=http://localhost:3000

# Optional overrides already read by the app (documented here for convenience).
# DATABASE_URL=sqlite:///data/events.db
# APP_ENV=local
# ENABLE_DOCS=false
# API_KEY=
# PROTECT_DASHBOARD=false
